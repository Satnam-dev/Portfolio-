MONGODB_URI=mongodb://127.0.0.1:27017/satnam_portfolio
# Or use Atlas: mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/satnam_portfolio
# If Atlas fails: MongoDB Atlas → Network Access → Add IP → Allow 0.0.0.0/0
# I built a full-stack personal portfolio website using Next.js and React for the frontend, Express.js and Node.js for the backend, and MongoDB as the database.
# The frontend is developed in TypeScript. I used Tailwind CSS, Framer Motion, and GSAP for styling and animations, and managed the project using Git and GitHub.
PORT=6000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# Set to true to always use an in-memory MongoDB in development
USE_MEMORY_DB=false

GROQ_API_KEY=your_groq_api_key

MAIL_HOST=smtp.gmail.com
MAIL_USER=your_email@gmail.com
MAIL_PASS=your_app_password

JWT_SECRET=your_jwt_secret

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
